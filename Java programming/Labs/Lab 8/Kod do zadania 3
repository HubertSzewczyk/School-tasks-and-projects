import java.util.ArrayList;
import java.util.Random;

public class Zadanie3 {
    public static void main(String[] args) {
        ArrayList<Integer> lista1 = generujListe(10, 20);
        ArrayList<Integer> lista2 = generujListe(10, 20);
        ArrayList<Integer> czescWspolna = new ArrayList<>();

        for (Integer liczba : lista1) {
            if (lista2.contains(liczba) && !czescWspolna.contains(liczba)) {
                czescWspolna.add(liczba);
            }
        }

        System.out.println("Lista 1: " + lista1);
        System.out.println("Lista 2: " + lista2);
        System.out.println("Wspólne liczby: " + czescWspolna);
    }

    private static ArrayList<Integer> generujListe(int rozmiar, int max) {
        ArrayList<Integer> list = new ArrayList<>();
        Random r = new Random();
        for (int i = 0; i < rozmiar; i++) list.add(r.nextInt(max) + 1);
        return list;
    }
}
