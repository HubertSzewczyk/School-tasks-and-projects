import java.util.ArrayList;
import java.util.Scanner;

public class Zadanie1 {
    public static void main(String[] args) {
        ArrayList<String> produkty = new ArrayList<>();
        Scanner scanner = new Scanner(System.in);

        System.out.println("Podaj 7 nazw produktów:");
        for (int i = 0; i < 7; i++) {
            System.out.print("Produkt " + (i + 1) + ": ");
            produkty.add(scanner.nextLine());
        }

        System.out.print("\nPodaj nazwę produktu do usunięcia: ");
        String doUsuniecia = scanner.nextLine();

        produkty.removeIf(p -> p.equalsIgnoreCase(doUsuniecia));

        System.out.println("Finalna lista: " + produkty);
        System.out.println("Liczba pozostałych produktów: " + produkty.size());
        scanner.close();
    }
}
