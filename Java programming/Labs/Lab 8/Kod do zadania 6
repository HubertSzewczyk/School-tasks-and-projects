import java.util.HashSet;
import java.util.Random;
import java.util.Set;

public class Zadanie6 {
    public static void main(String[] args) {
        HashSet<Integer> set1 = generujZbior(8, 15);
        HashSet<Integer> set2 = generujZbior(8, 15);

        System.out.println("Zbiór 1: " + set1);
        System.out.println("Zbiór 2: " + set2);

        // Część wspólna
        HashSet<Integer> czescWspolna = new HashSet<>(set1);
        czescWspolna.retainAll(set2);
        System.out.println("Część wspólna: " + czescWspolna);

        // Elementy będące tylko w jednym zbiorze
        HashSet<Integer> tylkoWJednym = new HashSet<>(set1);
        tylkoWJednym.addAll(set2); // Suma
        tylkoWJednym.removeAll(czescWspolna); // Suma minus część wspólna
        
        System.out.println("Elementy występujące tylko w jednym zbiorze: " + tylkoWJednym);
    }

    private static HashSet<Integer> generujZbior(int ilosc, int max) {
        HashSet<Integer> s = new HashSet<>();
        Random r = new Random();
        while(s.size() < ilosc) s.add(r.nextInt(max) + 1);
        return s;
    }
}
