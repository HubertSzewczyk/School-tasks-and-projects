class Ksiazka {
    String tytul;
    String autor;
    int liczbaStron;
    boolean przeczytana;

    public Ksiazka(String tytul, String autor, int liczbaStron, boolean przeczytana) {
        this.tytul = tytul;
        this.autor = autor;
        this.liczbaStron = liczbaStron;
        this.przeczytana = przeczytana;
    }

    public void oznaczJakoPrzeczytana() {
        this.przeczytana = true;
        System.out.println("Książka \"" + tytul + "\" została oznaczona jako przeczytana.");
    }

    public void wyswietlOpis() {
        String status = przeczytana ? "Przeczytana" : "Nieprzeczytana";
        System.out.println("Książka: " + tytul + ", Autor: " + autor + ", Stron: " + liczbaStron + " [" + status + "]");
    }

    public boolean czyDluga() {
        return liczbaStron > 300;
    }
}

public class Main {
    public static void main(String[] args){
        System.out.println("\n--- Zadanie 4: Ksiazka ---");
        Ksiazka k1 = new Ksiazka("Wiedźmin", "Andrzej Sapkowski", 320, false);
        Ksiazka k2 = new Ksiazka("Mały Książę", "A. de Saint-Exupéry", 90, true);
        Ksiazka k3 = new Ksiazka("Pan Tadeusz", "Adam Mickiewicz", 450, false);
        
        k1.wyswietlOpis();
        k1.oznaczJakoPrzeczytana();
        System.out.println("Czy k2 jest długa? " + k2.czyDluga());
        System.out.println("Czy k3 jest długa? " + k3.czyDluga());
    }
}
