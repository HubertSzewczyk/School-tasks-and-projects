import java.util.Random;
import java.util.Scanner;

public class Zadanie6 {
    public static void main(String[] args) {
        Random random = new Random();
        Scanner scanner = new Scanner(System.in);
        int[] tablica = new int[10];

        System.out.print("Wylosowana tablica: ");
        for (int i = 0; i < tablica.length; i++) {
            tablica[i] = random.nextInt(50) + 1;
            System.out.print(tablica[i] + " ");
        }

        System.out.print("\nPodaj wartość progową (1-50): ");
        int prog = scanner.nextInt();

        int suma = 0, licznik = 0;
        for (int liczba : tablica) {
            if (liczba > prog) {
                suma += liczba;
                licznik++;
            }
        }

        if (licznik > 0) {
            double srednia = (double) suma / licznik;
            System.out.println("Średnia elementów większych od " + prog + " wynosi: " + srednia);
        } else {
            System.out.println("W tablicy nie ma elementów większych od " + prog);
        }
        scanner.close();
    }
}
