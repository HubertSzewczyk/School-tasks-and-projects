Task 6
Write a program that simulates repeating verses of a song about beer, where the number of beer bottles on the wall decreases by one with each verse. 
The program should start with 10 bottles (the original number was 99) and stop when there are no bottles left. Each repetition should include the appropriate form of the number (one bottle vs. multiple bottles).

Complete the code snippet below to ensure the program runs correctly:

public class PiosenkaOPiwie {

   public static void main(String[] args) {

       int butelki = 10;  // Początkowa liczba butelek

	// Uzupełnij poniższą część kodu, jeśli będzie potrzebne dopisz "else if".

       while .............. {

            if ............. {

               System.out.println(butelki + " butelka piwa na ścianie,");

               System.out.println(butelki + " butelka piwa!");

               System.out.println("Weź jedną, przekaż dalej,");

               System.out.println("Nie ma butelek, by pić dalej!");

           } else {

               System.out.println(butelki + " butelek piwa na ścianie,");

               System.out.println(butelki + " butelek piwa!");

               System.out.println("Weź jedną, przekaż dalej,");

               System.out.println((butelki - 1) + " butelka piwa na ścianie!");

           }

           System.out.println();  // Pusta linia dla lepszej czytelności

           butelki--;  

       }

       

       System.out.println("Nie ma butelek piwa na ścianie!");

   }

}
