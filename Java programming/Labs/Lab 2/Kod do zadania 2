import java.util.*;
public class Trojkat {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        
        System.out.print("Podaj długośc trójkąta: ");
        int bok1 = scanner.nextInt();
        
        System.out.print("Podaj szerokość trójkąta: ");
        int bok2 = scanner.nextInt();
        
        
        System.out.print("Pole twojego trójkąta wynosi: " +(bok1*bok2)/2);
        
        scanner.close();
    }
}
