import java.util.Scanner;

public class Parking {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        
        System.out.print("Podaj liczbę godzin parkowania: ");
        int godziny = scanner.nextInt();
        
        int doZaplaty = 0;

        if (godziny <= 0) {
            doZaplaty = 0;
        } else if (godziny == 1) {
            doZaplaty = 5;
        } else {
            doZaplaty = 5 + (godziny - 1) * 3;
        }

        System.out.println("Opłata do zapłaty: " + doZaplaty + " zł");
        
        scanner.close();
    }
}
